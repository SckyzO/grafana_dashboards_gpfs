      "pluginVersion": "12.3.1",
      "options": {
        "mergeValues": true,
        "showValue": "auto",
        "fillOpacity": 70,
        "rowHeight": 0.9,
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        }
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
