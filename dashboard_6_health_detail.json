        "x": 0,
        "y": 5,
        "w": 24,
        "h": 1
      },
      "panels": []
    },
    {
      "type": "table",
      "title": "Health Status per Component — $node",
      "description": "Health status of each GPFS component on the selected node",
      "id": 5,
      "gridPos": {
        "x": 0,
        "y": 6,
        "w": 14,
        "h": 12
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "pluginVersion": "12.3.1",
      "options": {
        "footer": {
          "show": false
        },
        "showHeader": true,
        "cellHeight": "sm",
        "sortBy": []
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "custom": {
            "align": "left",
            "inspect": false
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Status"
            },
            "properties": [
              {
                "id": "custom.displayMode",
                "value": "color-background"
              },
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "10": {
                        "text": "HEALTHY",
                        "color": "green",
                        "index": 0
                      },
                      "20": {
                        "text": "DEGRADED",
                        "color": "orange",
                        "index": 1
                      },
                      "30": {
                        "text": "ERROR",
                        "color": "red",
                        "index": 2
                      }
                    }
                  }
                ]
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "green",
                      "value": null
                    },
                    {
                      "color": "orange",
                      "value": 20
                    },
                    {
                      "color": "red",
                      "value": 30
                    }
                  ]
                }
              }
            ]
          }
        ]
      },
