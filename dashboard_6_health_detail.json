{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "type": "datasource",
      "pluginId": "prometheus"
    }
  ],
  "__requires": [
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    }
  ],
  "id": null,
  "uid": "gpfs-health-detail-prod",
  "title": "06 — GPFS Cluster Health by Node",
  "description": "Detailed GPFS health drill-down per node and component — link from Overview",
  "tags": [
    "gpfs",
    "health",
    "production"
  ],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "schemaVersion": 42,
  "version": 2,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {},
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "Datasource",
        "multi": false,
        "name": "datasource",
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      },
      {
        "current": {},
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "definition": "label_values(gpfs_health_status, cluster)",
        "hide": 0,
        "includeAll": false,
        "label": "Cluster",
        "multi": false,
        "name": "cluster",
        "query": {
          "query": "label_values(gpfs_health_status, cluster)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "sort": 1,
        "type": "query"
      },
      {
        "current": {},
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "definition": "label_values(gpfs_health_status{cluster=\"$cluster\"}, node)",
        "hide": 0,
        "includeAll": false,
        "label": "Node",
        "multi": false,
        "name": "node",
        "query": {
          "query": "label_values(gpfs_health_status{cluster=\"$cluster\"}, node)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "annotations": {
    "list": []
  },
  "links": [
    {
      "title": "GPFS Dashboards",
      "type": "dashboards",
      "tags": [
        "gpfs"
      ],
      "asDropdown": true,
      "includeVars": true,
      "keepTime": true,
      "icon": "external link",
      "targetBlank": false
