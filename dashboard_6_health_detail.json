          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "spanNulls": false,
            "showPoints": "never",
            "lineInterpolation": "smooth",
            "stacking": {
              "group": "A",
              "mode": "none"
            },
            "thresholdsStyle": {
