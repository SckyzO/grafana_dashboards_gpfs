        "definition": "label_values(gpfs_pool_total_dataKB{cluster=\"$cluster\"}, gpfs_diskpool_name)",
        "hide": 0,
        "includeAll": true,
        "label": "Pool",
        "multi": true,
        "name": "pool",
        "query": {
          "query": "label_values(gpfs_pool_total_dataKB{cluster=\"$cluster\"}, gpfs_diskpool_name)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "sort": 1,
        "type": "query"
      }
    ]
  },
