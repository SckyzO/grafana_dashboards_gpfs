        "includeAll": true,
        "label": "Node",
        "multi": true,
        "name": "node",
        "query": {
          "query": "label_values(gpfs_ns_bytes_read{cluster=\"$cluster\"}, node)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "annotations": {
    "list": []
  },
  "links": [
    {
      "title": "GPFS Dashboards",
      "type": "dashboards",
      "tags": [
        "gpfs"
