  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "schemaVersion": 42,
  "version": 2,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {},
