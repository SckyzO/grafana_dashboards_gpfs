    {
      "type": "timeseries",
      "title": "Read Throughput per Node",
      "description": "",
      "id": 1,
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 12,
        "h": 9
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "pluginVersion": "12.3.1",
      "options": {
        "legend": {
          "calcs": [
            "mean",
            "max",
            "lastNotNull"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "Bps",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "spanNulls": false,
            "showPoints": "never",
            "lineInterpolation": "smooth",
            "stacking": {
              "group": "A",
              "mode": "none"
            },
            "thresholdsStyle": {
              "mode": "off"
            }
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "irate(gpfs_ns_bytes_read{cluster=\"$cluster\", node=~\"$node\"}[5m])",
          "legendFormat": "{{node}}",
          "refId": "A"
        }
      ]
