    }
  ],
  "id": null,
  "uid": "gpfs-vfsx-prod",
  "title": "05 — GPFS VFS Latency (VFSX)",
  "description": "VFS kernel operations: call rates and average latencies for read, write, open, close, create, lookup",
  "tags": [
    "gpfs",
    "vfsx",
    "latency",
    "production"
  ],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "schemaVersion": 42,
  "version": 2,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {},
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "Datasource",
        "multi": false,
        "name": "datasource",
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      },
      {
        "current": {},
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "definition": "label_values(gpfs_vfsx_read, cluster)",
        "hide": 0,
        "includeAll": false,
        "label": "Cluster",
        "multi": false,
        "name": "cluster",
        "query": {
          "query": "label_values(gpfs_vfsx_read, cluster)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "sort": 1,
        "type": "query"
      },
      {
        "current": {},
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "definition": "label_values(gpfs_vfsx_read{cluster=\"$cluster\"}, node)",
        "hide": 0,
        "includeAll": true,
        "label": "Node",
        "multi": true,
        "name": "node",
        "query": {
          "query": "label_values(gpfs_vfsx_read{cluster=\"$cluster\"}, node)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "annotations": {
    "list": []
  },
  "links": [
    {
      "title": "GPFS Dashboards",
      "type": "dashboards",
      "tags": [
        "gpfs"
      ],
      "asDropdown": true,
      "includeVars": true,
      "keepTime": true,
      "icon": "external link",
      "targetBlank": false
    },
    {
      "title": "GitHub",
      "type": "link",
      "url": "https://github.com/SckyzO/grafana_dashboards_gpfs",
      "targetBlank": true,
      "icon": "external link"
    }
  ],
  "panels": [
    {
      "type": "row",
      "title": "VFS Operation Rates",
      "id": 100,
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 1
      },
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Read / Write Operations per Node (ops/s)",
      "description": "",
      "id": 1,
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 24,
        "h": 9
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "pluginVersion": "12.3.1",
      "options": {
        "legend": {
          "calcs": [
            "mean",
            "max",
            "lastNotNull"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "ops",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": false,
            "showPoints": "never",
            "lineInterpolation": "smooth",
            "stacking": {
              "group": "A",
              "mode": "none"
            },
            "thresholdsStyle": {
              "mode": "off"
            }
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "rate(gpfs_vfsx_read{cluster=\"$cluster\", node=~\"$node\"}[2m])",
          "legendFormat": "{{node}} — read",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "rate(gpfs_vfsx_write{cluster=\"$cluster\", node=~\"$node\"}[2m])",
          "legendFormat": "{{node}} — write",
          "refId": "B"
        }
      ]
    },
