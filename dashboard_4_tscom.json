      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "pluginVersion": "12.3.1",
      "options": {
        "footer": {
          "show": false
        },
        "showHeader": true,
        "cellHeight": "sm",
        "sortBy": []
