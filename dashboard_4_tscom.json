      "gridPos": {
        "x": 0,
        "y": 6,
        "w": 16,
        "h": 9
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "pluginVersion": "12.3.1",
      "options": {
        "legend": {
          "calcs": [
            "mean",
            "max",
            "lastNotNull"
          ],
          "displayMode": "table",
          "placement": "bottom",
