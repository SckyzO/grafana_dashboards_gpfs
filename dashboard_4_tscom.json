          "id": "labelsToFields",
          "options": {
            "mode": "columns"
          }
        },
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "cluster": true,
              "env": true,
              "instance": true,
              "job": true,
              "gpfs_tscom_connection": true
            },
            "renameByName": {
              "node": "Source Node",
              "gpfs_tscom_destination": "Destination",
              "Value": "RTT (µs)"
            }
          }
        }
      ],
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
