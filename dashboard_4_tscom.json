{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "type": "datasource",
      "pluginId": "prometheus"
    }
  ],
  "__requires": [
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    }
  ],
  "id": null,
  "uid": "gpfs-tscom-prod",
  "title": "04 — GPFS TSCOM Inter-node Communication",
  "description": "GPFS TCP inter-node communication: link state, RTT, retransmissions and traffic",
  "tags": [
    "gpfs",
    "tscom",
    "network",
    "production"
  ],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "schemaVersion": 42,
  "version": 2,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {},
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "Datasource",
        "multi": false,
        "name": "datasource",
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      },
      {
        "current": {},
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "definition": "label_values(gpfs_tscom_stat, cluster)",
        "hide": 0,
        "includeAll": false,
        "label": "Cluster",
        "multi": false,
        "name": "cluster",
        "query": {
          "query": "label_values(gpfs_tscom_stat, cluster)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "sort": 1,
        "type": "query"
      },
      {
        "current": {},
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "definition": "label_values(gpfs_tscom_stat{cluster=\"$cluster\"}, node)",
        "hide": 0,
        "includeAll": true,
        "label": "Source Node",
        "multi": true,
        "name": "node",
        "query": {
          "query": "label_values(gpfs_tscom_stat{cluster=\"$cluster\"}, node)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "annotations": {
    "list": []
  },
  "links": [
    {
      "title": "GPFS Dashboards",
      "type": "dashboards",
      "tags": [
        "gpfs"
      ],
      "asDropdown": true,
      "includeVars": true,
      "keepTime": true,
      "icon": "external link",
      "targetBlank": false
    },
    {
      "title": "GitHub",
      "type": "link",
      "url": "https://github.com/SckyzO/grafana_dashboards_gpfs",
      "targetBlank": true,
      "icon": "external link"
    }
  ],
  "panels": [
    {
      "type": "row",
      "title": "Connection State",
      "id": 100,
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 1
      },
      "panels": []
    },
    {
      "type": "stat",
      "title": "Active Links",
      "description": "Number of TSCOM links in connected state",
      "id": 1,
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "pluginVersion": "12.3.1",
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 1
              },
              {
                "color": "green",
                "value": 10
              }
            ]
          },
          "unit": "short",
          "mappings": []
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum(gpfs_tscom_stat{cluster=\"$cluster\", node=~\"$node\"} == 1)",
          "legendFormat": "",
          "refId": "A",
          "instant": true,
          "range": false
        }
      ]
    },
    {
      "type": "stat",
      "title": "Lost Links",
      "description": "Number of disconnected TSCOM links — should stay at 0",
      "id": 2,
      "gridPos": {
        "x": 6,
        "y": 1,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "pluginVersion": "12.3.1",
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          },
          "unit": "short",
          "mappings": []
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum(gpfs_tscom_stat{cluster=\"$cluster\", node=~\"$node\"} == 0) OR vector(0)",
          "legendFormat": "",
          "refId": "A",
          "instant": true,
          "range": false
        }
      ]
    },
