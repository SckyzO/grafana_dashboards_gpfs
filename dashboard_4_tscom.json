      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "custom": {
            "align": "left",
            "inspect": false
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "RTT (µs)"
            },
            "properties": [
              {
                "id": "unit",
                "value": "µs"
              },
              {
                "id": "custom.displayMode",
                "value": "color-background"
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "green",
                      "value": null
                    },
                    {
                      "color": "orange",
                      "value": 1000
                    },
                    {
                      "color": "red",
                      "value": 5000
                    }
                  ]
                }
              }
            ]
          }
        ]
      },
      "transformations": [
